@using LumexUI.Common
@using LumexUI.Shared.Icons

@inject AppDbContext Db

<LumexModal>
    <LumexModalTrigger Variant="@Variant.Flat" Color="@ButtonColor" OnClick="OnOpen" >
        <SwordsIcon />
        @ButtonText
    </LumexModalTrigger>

    <LumexModalContent Context="modal">

        <LumexModalHeader>
            Add New Faction
        </LumexModalHeader>

        <LumexModalBody>

            <LumexSelect TValue="mdGame" Label="Select a Game" @bind-Value="_selectedGame" Required>
                @foreach (var game in _games)
                {
                    <LumexSelectItem @key="@game" Value="game" TextValue="@game.Name">@game.Name</LumexSelectItem>
                }
            </LumexSelect>

            <LumexTextbox Label="Name"
                          Required
                          @bind-Value="_model.Name"
                          Placeholder="Enter faction name"
                          Variant="@InputVariant.Outlined" />

            <LumexSelect TValue="ColorChoice" Label="Select color" @bind-Value="_selectedColor">
                <ChildContent>
                    @foreach (var color in _colorChoice)
                    {
                        <LumexSelectItem @key="@color" Value="color" TextValue="@color.Name">
                            <LumexUser Name="@color.Name">
                                <AvatarContent>
                                    <div style="width:30px;height:30px;background:@color.hex;border-radius:50%;"/>
                                </AvatarContent>
                            </LumexUser>
                        </LumexSelectItem>
                    }
                </ChildContent>
                <ValueContent>
                    <LumexUser Name="@context.Name">
                        <AvatarContent>
                            <div style="width:15px;height:15px;background:@context.hex;border-radius:50%;" />
                        </AvatarContent>
                    </LumexUser>
                </ValueContent>
            </LumexSelect>

            @if(_alertContent is not null)
            {
                <LumexAlert Color="ThemeColor.Danger" Title="@_alertContent" />
            }

        </LumexModalBody>


        <LumexModalFooter>

            <LumexButton Color="@ThemeColor.Danger"
                         Variant="@Variant.Flat"
                         OnClick="@modal.CloseAsync">
                Cancel
            </LumexButton>

            <LumexButton Color="@ThemeColor.Primary"
                         Variant="@Variant.Solid"
                         OnClick="async () => await SaveGame(modal, false)">
                Save and Next
            </LumexButton>

            <LumexButton Color="@ThemeColor.Primary"
                         Variant="@Variant.Solid"
                         OnClick="async () => await SaveGame(modal, true)">
                Save and Close
            </LumexButton>
        </LumexModalFooter>

    </LumexModalContent>
</LumexModal>
@code {
    [Parameter] public EventCallback OnCreated { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public mdFaction? Faction { get; set; }
    [Parameter] public string? ButtonText { get; set; }
    [Parameter] public ThemeColor ButtonColor { get; set; }

    private mdFaction _model = new();

    private mdGame? _selectedGame;
    private ColorChoice? _selectedColor;

    private string? _alertContent = null;

    private IQueryable<mdGame> _games => Db.Games;

    private ColorChoice[] _colorChoice =
    [
        new("white", "#FFFFFF"),
        new("black", "#2D3436"),
        new("gray", "#7F8C8D"),

        new("red", "#F54927"),
        new("blue", "#3498DB"),
        new("green", "#2ECC71"),

        new("yellow", "#F1C40F"),
        new("orange", "#F39C12"),

        new("purple", "#9B59B6"),
        new("pink", "#E91E63"),

        new("teal", "#1ABC9C"),
        new("navy", "#2C3E50"),

        new("brown", "#8D6E63"),
        new("violet", "#8E44AD"),
        new("rose", "#FF5C8A")
    ];

    private record ColorChoice(string Name, string hex);


    protected override void OnParametersSet()
    {

        if (Faction is null)
        {
            _model = new mdFaction();
            _selectedGame = null;
            _selectedColor = null;
        }
        else
        {


            _model = new mdFaction
            {
                Id = Faction.Id,
                Name = Faction.Name,
                Color = Faction.Color,
                GameId = Faction.GameId
            };

            _selectedGame = _games.FirstOrDefault(g => g.Id == Faction.GameId);
            _selectedColor = _colorChoice.FirstOrDefault(c => c.hex == Faction.Color);
        }
    }

    private void OnOpen()
    {
        _alertContent = null;
    }

    private async Task SaveGame(LumexModal modal, bool close)
    {
        _alertContent = null;

        if (_selectedGame is null)
        {
            _alertContent = "Please select a game.";
            return;
        }

        if (_model.Name is null || _model.Name == string.Empty)
        {
            _alertContent = "Please select a name.";
            return;
        }

        if (_model.Id == 0)
        {
            _model.GameId = _selectedGame.Id;
            _model.Color = _selectedColor?.hex ?? "#000000";
            Db.Factions.Add(_model);
        }
        else
        {
            var existing = await Db.Factions.FindAsync(_model.Id);

            if (existing != null)
            {
                existing.Name = _model.Name;
                existing.GameId = _selectedGame.Id;
                existing.Color = _selectedColor.hex;
            }
        }


        await Db.SaveChangesAsync();


        if (close){
            await OnSaved.InvokeAsync();
            _model = null;
            await modal.CloseAsync();
        }
        else
        {
            _model = new mdFaction();
            _selectedColor = null;
            _model.GameId = _selectedGame.Id;
        }
    }
}
