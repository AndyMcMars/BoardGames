@using LumexUI.Common

@inject AppDbContext Db

<LumexModal>
    <LumexModalTrigger Variant="@Variant.Flat" Color="@ButtonColor" OnClick="OnOpen">
        <MapPinIcon />
        @ButtonText
    </LumexModalTrigger>

    <LumexModalContent Context="modal">

        <LumexModalHeader>
            Add Location
        </LumexModalHeader>

        <LumexModalBody>

            <LumexTextbox Label="Name"
                          Required
                          @bind-Value="_model.Description"
                          Placeholder="Enter location name"
                          Variant="@InputVariant.Outlined" />
                          

            @if (_alertContent is not null)
            {
                <LumexAlert Color="ThemeColor.Danger" Title="@_alertContent" />
            }


        </LumexModalBody>

        <LumexModalFooter>

            <LumexButton Color="@ThemeColor.Danger"
                         Variant="@Variant.Flat"
                         OnClick="@modal.CloseAsync">
                Cancel
            </LumexButton>

            <LumexButton Color="@ThemeColor.Primary"
                         Variant="@Variant.Solid"
                         OnClick="async () => await SaveLocation(modal)">
                Save
            </LumexButton>

        </LumexModalFooter>

    </LumexModalContent>
</LumexModal>

@code {

    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public mdLocation? Location { get; set; }
    [Parameter] public string? ButtonText { get; set; }
    [Parameter] public ThemeColor ButtonColor { get; set; }
    
    private mdLocation _model = new();
    private string? _alertContent;
    
    protected override void OnParametersSet()
    {
        if (Location is null)
        {
            _model = new mdLocation();
        }
        else
        {
            _model = new mdLocation
            {
                Id = Location.Id,
                Description = Location.Description
            };
        }
    }

    private void OnOpen()
    {
        _alertContent = null;
    }

    private async Task SaveLocation(LumexModal modal)
    {
        
        if (_model.Description is null || _model.Description == "")
        {
            _alertContent = "Please give a Name.";
            return;
        }

        if (_model.Id == 0)
        {
            Db.Locations.Add(_model);
        }
        else
        {
            var existing = await Db.Locations.FindAsync(_model.Id);

            if (existing != null)
            {
                existing.Description = _model.Description;
            }
        }

        await Db.SaveChangesAsync();

        await OnSaved.InvokeAsync();

        await modal.CloseAsync();
    }
}