@using LumexUI.Common
@using Microsoft.EntityFrameworkCore

@inject AppDbContext Db

<LumexModal>
    <LumexModalTrigger Variant="@Variant.Flat" Color="@ButtonColor">
        <DiceIcon/>
        @ButtonText
    </LumexModalTrigger>

    <LumexModalContent Context="modal">

        <LumexModalHeader>
            Add New Game
        </LumexModalHeader>

        <LumexModalBody>

            <LumexTextbox Label="Name"
                          Value="@_model.Name"
                          ValueChanged="OnNameChanged"
                          ValueExpression="@(() => _model.Name)"
                          Placeholder="Enter game name"
                          Variant="@InputVariant.Outlined" />

            <LumexTextbox Label="Image URL"
                          @bind-Value="_model.Image"
                          Placeholder="Optional image URL"
                          Variant="@InputVariant.Outlined" />

            <LumexDivider />
            <LumexAlert Color="@ThemeColor.Info" Title="Game slug:" Description="@_model.Slug"/>
        </LumexModalBody>

        <LumexModalFooter>

            <LumexButton Color="@ThemeColor.Danger"
                         Variant="@Variant.Flat"
                         OnClick="@modal.CloseAsync">
                Cancel
            </LumexButton>

            <LumexButton Color="@ThemeColor.Primary"
                         Variant="@Variant.Solid"
                         OnClick="async () => await SaveGame(modal)">
                Save
            </LumexButton>

        </LumexModalFooter>

    </LumexModalContent>
</LumexModal>

@code {

    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public mdGame? Game { get; set; }
    [Parameter] public string? ButtonText { get; set; }
    [Parameter] public ThemeColor ButtonColor { get; set; }

    private mdGame _model;

    protected override void OnParametersSet()
    {
        if (Game is null)
        {
            _model = new mdGame();
        }
        else
        {
            _model = new mdGame
            {
                Id = Game.Id,
                Name = Game.Name,
                Image = Game.Image
            };
        }
    }

    private void OnNameChanged(string value)
    {
        _model.Name = value;
        _model.Slug = GenerateSlug(value);
    }

    private string GenerateSlug(string name)
    {
        return name
                .ToLower()
                .Trim()
                .Replace(" ", "_");
    }

    private async Task SaveGame(LumexModal modal)
    {
        var slug = GenerateSlug(_model.Name);
        var exists = await Db.Games.AnyAsync(g => g.Slug == slug && g.Id != _model.Id);

        if (exists)
        {
            return;
        }

        if (_model.Id == 0)
        {
            _model.Slug = slug;
            Db.Games.Add(_model);
        }
        else
        {
            var existing = await Db.Games.FindAsync(_model.Id);

            if (existing != null)
            {
                existing.Name = _model.Name;
                existing.Image = _model.Image;
            }
        }

        await Db.SaveChangesAsync();

        await OnSaved.InvokeAsync();

        await modal.CloseAsync();
    }
}