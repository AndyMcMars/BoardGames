@using LumexUI.Common

@inject AppDbContext Db

<LumexModal>
    <LumexModalTrigger Variant="@Variant.Flat" Color="@ThemeColor.Primary">
        + Add Player
    </LumexModalTrigger>

    <LumexModalContent Context="modal">

        <LumexModalHeader>
            Add Player
        </LumexModalHeader>

        <LumexModalBody>

            <LumexTextbox Label="Name"
                          @bind-Value="_newPlayer.Name"
                          Placeholder="Enter game name"
                          Variant="@InputVariant.Outlined" />


        </LumexModalBody>

        <LumexModalFooter>

            <LumexButton Color="@ThemeColor.Danger"
                         Variant="@Variant.Flat"
                         OnClick="@modal.CloseAsync">
                Cancel
            </LumexButton>

            <LumexButton Color="@ThemeColor.Primary"
                         Variant="@Variant.Solid"
                         OnClick="async () => await SaveGame(modal)">
                Save
            </LumexButton>

        </LumexModalFooter>

    </LumexModalContent>
</LumexModal>

@code {

    [Parameter]
    public EventCallback OnCreated { get; set; }

    private mdPlayer _newPlayer = new();

    private async Task SaveGame(LumexModal modal)
    {
        Db.Players.Add(_newPlayer);
        await Db.SaveChangesAsync();

        _newPlayer = new mdPlayer();

        await OnCreated.InvokeAsync();

        await modal.CloseAsync();
    }
}