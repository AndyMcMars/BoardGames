@using LumexUI.Common
@using LumexUI.Shared.Icons

@inject AppDbContext Db

<LumexModal>
    <LumexModalTrigger Variant="@Variant.Flat" Color="@ButtonColor">
        <UserIcon/>
        @ButtonText
    </LumexModalTrigger>

    <LumexModalContent Context="modal">

        <LumexModalHeader>
            Add Player
        </LumexModalHeader>

        <LumexModalBody>

            <LumexTextbox Label="Name"
                          Required
                          @bind-Value="_model.Name"
                          Placeholder="Enter Player name"
                          Variant="@InputVariant.Outlined" />
                          
            @if (_alertContent is not null)
            {
                <LumexAlert Color="ThemeColor.Danger" Title="@_alertContent" />
            }

        </LumexModalBody>

        <LumexModalFooter>

            <LumexButton Color="@ThemeColor.Danger"
                         Variant="@Variant.Flat"
                         OnClick="@modal.CloseAsync">
                Cancel
            </LumexButton>

            <LumexButton Color="@ThemeColor.Primary"
                         Variant="@Variant.Solid"
                         OnClick="async () => await SavePlayer(modal)">
                Save
            </LumexButton>

        </LumexModalFooter>

    </LumexModalContent>
</LumexModal>

@code {

    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public mdPlayer? Player { get; set; }
    [Parameter] public string? ButtonText { get; set; }
    [Parameter] public ThemeColor ButtonColor { get; set; }

    private mdPlayer _model = new();
    private string? _alertContent;


    protected override void OnParametersSet()
    {
        if (Player is null)
        {
            _model = new mdPlayer();
        }
        else
        {
            _model = new mdPlayer
            {
                Id = Player.Id,
                Name = Player.Name
            };
        }
    }


    private async Task SavePlayer(LumexModal modal)
    {
        _alertContent = null;

        if(_model.Name is null || _model.Name == "")
        {
            _alertContent = "Please give a name.";
            return;
        }

        if (_model.Id == 0)
        {
            Db.Players.Add(_model);
        }
        else
        {
            var existing = await Db.Players.FindAsync(_model.Id);

            if (existing != null)
            {
                existing.Name = _model.Name;
            }
        }


        await Db.SaveChangesAsync();

        await OnSaved.InvokeAsync();

        await modal.CloseAsync();
    }
}