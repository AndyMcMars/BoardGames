@page "/{game_slug}"
@using LumexUI.Common
@using LumexUI.Shared.Icons
@using Microsoft.EntityFrameworkCore;

@inject AppDbContext Db
@inject NavigationManager Nav

<div class="flex items-center gap-2 mb-4">
    <LumexLink Href="/">@SharedResource.Settings_Games</LumexLink>
</div>

@if (_game is null)
{
    <p>@SharedResource.GameMatches_GameNotFound</p>
}
else
{
    <LumexCard Class="mb-4">
        <LumexCardHeader Class="flex gap-4 items-start">
            <img src="@_game.Image" width="200" />
            <div class="flex flex-col gap-3 items-start w-full">
                <p class="text-xl font-bold">@_game.Name</p>
                <LumexChip Variant="ChipVariant.Light">
                    <EndContent>
                        @_totalMatches
                    </EndContent>
                    <ChildContent>
                        <SwordsIcon />
                    </ChildContent>
                </LumexChip>
                <LumexChip Variant="ChipVariant.Light">
                    <EndContent>
                        @_tournaments.Count
                    </EndContent>
                    <ChildContent>
                        <TrophyIcon />
                    </ChildContent>
                </LumexChip>
                <LumexChip Variant="ChipVariant.Light">
                    <EndContent>
                        @_totalDuration.ToString(@"hh\:mm")
                    </EndContent>
                    <ChildContent>
                        <TimerIcon />
                    </ChildContent>
                </LumexChip>
            </div>
        </LumexCardHeader>
    </LumexCard>


    @if (_matches.Any() || _tournaments.Any())
    {
        <LumexDivider />

        <LumexAccordion ItemClasses="_itemClasses" >
            <LumexAccordionItem Id="1" Title="@($"{@SharedResource.GameMatches_Leaderboards} - {DateTime.Now.Year}")">
                <StartContent>
                    <MedalIcon />
                </StartContent> 
                <ChildContent>
                    <LumexDataGrid T="PlayerStats" Data="_leaderboard.AsQueryable()" Color="ThemeColor.Primary" Shadow="0">
                        <PropertyColumn Property="@(p => p.Rank)" Title="@SharedResource.GameMatches_Nr" />
                        <PropertyColumn Property="@(p => p.PlayerName)" Title="@SharedResource.Match_Player" />
                        <PropertyColumn Property="@(p => p.MatchesPlayed)" Title="@SharedResource.GameMatches_Matches" />
                        <PropertyColumn Property="@(p => p.Wins)" Title="@SharedResource.GameMatches_Wins" />
                        <PropertyColumn Property="@(p => p.WinRate)" Title="@SharedResource.GameMatches_Win" />
                    </LumexDataGrid>
                </ChildContent>
            </LumexAccordionItem>
        </LumexAccordion>

        <LumexDivider Class="mb-4" />

        <LumexTabs>
            <LumexTab Title="@SharedResource.GameMatches_Matches">
                <LumexDataGrid Data="@_matches.AsQueryable()" T=mdMatch Layout="Layout.Fixed" OnRowClick="@GoToMatch" Classes="_classes" Hoverable>
                    <PropertyColumn Title="@SharedResource.GameMatches_Date" Property="@(p => p.Date)" Format="dd.MM.yy" Sortable="true" />
                    <TemplateColumn HeaderContent="HeaderContent" Context="p" Sortable="true">
                        @(p.Results.Count())
                    </TemplateColumn>
                    <TemplateColumn Title="@SharedResource.GameMatches_Winner" Context="p" Sortable="true">
                        @($"{p.Winner?.Player?.Name} ({p.Winner?.Points})" ?? "")
                    </TemplateColumn>
                    <TemplateColumn Title="Winner faction" Context="p" Sortable="true">
                        <LumexUser Name="@p.WinnerFaction?.Name">
                            <AvatarContent>
                                <div style="width:15px;height:15px;background:@p.WinnerFaction?.Color;border-radius:50%;" />
                            </AvatarContent>
                        </LumexUser>
                    </TemplateColumn>
                </LumexDataGrid>
            </LumexTab>
            <LumexTab Title="@SharedResource.GameMatches_Tournaments">
                <LumexDataGrid Data="@_tournaments.AsQueryable()" T="mdTournament" Layout="Layout.Fixed" OnRowClick="@GoToTournement" Hoverable Classes="_classes">
                    <PropertyColumn Property="@(p=>p.Name)" />
                    <PropertyColumn Property="@(p => p.Matches.Count)" Title="@SharedResource.GameMatches_Matches" />
                    <TemplateColumn Title="@SharedResource.GameMatches_Winner" Context="p" Sortable="true">
                        @($"{p.Winner?.Player?.Name} ({p.Winner?.TotalPoints})" ?? "")
                    </TemplateColumn>
                    <TemplateColumn Title="@SharedResource.GameMatches_Status" Context="p">
                        @if (p.IsActive)
                        {
                            <LockOpen />
                        }
                        else
                        {
                            <Lock/>
                        }
                    </TemplateColumn>
                </LumexDataGrid>
            </LumexTab>
        </LumexTabs>

    }
    else
    {
        <LumexAlert Title="@SharedResource.GameMatches_NoMatchFound"
                    Description="@($"{@SharedResource.GameMatches_ThereAreCurrentlyNoMatchesFor} {_game.Name}")" />
    }

}



@code {

    [Parameter] public string game_slug { get; set; }

    private mdGame? _game;
    private int _totalMatches;

    private DataGridSlots _classes = new()
    {
        Tr = "cursor-pointer"
        
    };

    private RenderFragment<LumexColumnBase<mdMatch>> HeaderContent => context =>
    @<div class="flex items-center gap-2">
        <UsersIcon class="w-3 h-3" />
    </div>;

    private AccordionItemSlots _itemClasses = new()
    {
        Title = "text-xl font-bold",
    };

    private List<mdMatch> _matches = new();
    private List<mdTournament> _tournaments = new();

    private List<PlayerStats> _leaderboard = new();

    private TimeSpan _totalDuration;

    protected override async Task OnParametersSetAsync()
    {
        _game = await Db.Games
            .FirstOrDefaultAsync(g => g.Slug == game_slug);

        if (_game == null) return;

        _totalMatches = await Db.Matches
            .Where(m => m.GameId == _game.Id)
            .CountAsync();

        _totalDuration = (await Db.Matches
            .Where(m => m.GameId == _game.Id && m.Duration.HasValue)
            .Select(m => m.Duration!.Value)
            .ToListAsync())
            .Aggregate(TimeSpan.Zero, (a, b) => a + b);

        _matches = await Db.Matches
            .Where(m => m.GameId == _game.Id && m.TournamentId == null)
            .Include(m => m.Location)
            .Include(m => m.Results)
                .ThenInclude(r => r.Player)
            .Include(m => m.Results)
                .ThenInclude(r => r.Faction)
            .OrderByDescending(m => m.Date)
            .ToListAsync();

        _tournaments = await Db.Tournaments
            .Where(t => t.GameId == _game.Id && t.Matches.Count > 0)
            .Include(t => t.Matches)
                .ThenInclude(m => m.Results)
                    .ThenInclude(r => r.Player)
            .ToListAsync();

        var matches = await Db.Matches
            .Where(m => m.GameId == _game.Id && m.Date.Year == DateTime.Now.Year)
            .Include(m => m.Results)
                .ThenInclude(r => r.Player)
            .ToListAsync();

        _leaderboard = matches
            .Select(m => new
            {
                m.Results,
                WinnerPlayerId = m.Results
                    .OrderByDescending(r => r.Points)
                    .Select(r => r.PlayerId)
                    .FirstOrDefault()
            })
            .SelectMany(m => m.Results, (m, r) => new
            {
                r.PlayerId,
                PlayerName = r.Player.Name,
                IsWin = r.PlayerId == m.WinnerPlayerId
            })
            .Where(p => p.PlayerId != -1)
            .GroupBy(x => new { x.PlayerId, x.PlayerName })
            .Select(g => new
            {
                PlayerName = g.Key.PlayerName,
                MatchesPlayed = g.Count(),
                Wins = g.Count(x => x.IsWin),
                WinRate = g.Count(x => x.IsWin) / (double)g.Count()
            })
            .OrderByDescending(x => x.WinRate)
            .ThenByDescending(x => x.Wins)
            .Select((x, i) => new PlayerStats
            {
                Rank = i + 1,
                PlayerName = x.PlayerName,
                MatchesPlayed = x.MatchesPlayed,
                Wins = x.Wins,
                WinRate = Math.Round(x.WinRate * 100, 1)
            })
            .ToList();
    }

    private void GoToMatch(DataGridRowClickEventArgs<mdMatch> match)
    {
        Nav.NavigateTo($"/{game_slug}/{match.Item.PublicId}");
    }

    private void GoToTournement(DataGridRowClickEventArgs<mdTournament> tournament)
    {
        Nav.NavigateTo($"/{game_slug}/tournament/{tournament.Item.PublicId}");
    }

    public class PlayerStats
    {
        public int Rank { get; set; }
        public string PlayerName { get; set; } = "";
        public int MatchesPlayed { get; set; }
        public int Wins { get; set; }
        public double WinRate { get; set; }
    }
}
