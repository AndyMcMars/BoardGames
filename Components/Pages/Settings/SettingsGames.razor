@using LumexUI.Common
@using Microsoft.EntityFrameworkCore

@inject AppDbContext Db
@inject NavigationManager Nav


<LumexDataGrid Data="@_games" SelectionMode="@SelectionMode.Multiple" @bind-SelectedItems="_selectedGames" @key="_refreshKey">
    <ToolbarContent>
        <div class="max-w-sm">
            <ModalGame OnGameCreated="UpdateData" />
            <LumexButton OnClick="DeleteSelected" Disabled="_selectedGames.Count < 1">Delete Selected</LumexButton>
        </div>
    </ToolbarContent>
    <ChildContent>
        <PropertyColumn Property="@(p => p.Image )">
            <Content>
                <img src="@context.Image" width="100" />
            </Content>
        </PropertyColumn>
        <PropertyColumn Property="@(p => p.Name)" />
    </ChildContent>
</LumexDataGrid>

@code {
    private IQueryable<mdGame> _games => Db.Games;
    private ICollection<mdGame> _selectedGames = [];
    private int _refreshKey;

    protected override async Task OnInitializedAsync()
    {
        await UpdateData();
    }

    private async Task UpdateData()
    {
        _refreshKey++;
        StateHasChanged();
    }


    private async Task DeleteSelected()
    {
        Db.Games.RemoveRange(_selectedGames);
        await Db.SaveChangesAsync();
        await UpdateData();
    }

}

