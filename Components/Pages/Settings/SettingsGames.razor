@using LumexUI.Common
@using LumexUI.Shared.Icons
@using Microsoft.EntityFrameworkCore

@inject AppDbContext Db
@inject NavigationManager Nav


<LumexDataGrid Data="@_games" SelectionMode="@SelectionMode.Multiple" @bind-SelectedItems="_selectedGames" @key="_refreshKey">
    <ToolbarContent>
        <div class="flex justify-between">
            <ModalGame ButtonText="@(_selectedGames.Count == 1 ? "Edit Game" : "Add Game")" Game="_selectedGames.FirstOrDefault()" OnSaved="UpdateData" ButtonColor="@(_selectedGames.Count == 1 ? ThemeColor.Warning : ThemeColor.Success)" />
            <LumexButton OnClick="() => _showDeleteModal = true" Disabled="_selectedGames.Count < 1" Color="@(_selectedGames.Count < 1 ? ThemeColor.Default : ThemeColor.Danger)">
                <Trash2Icon/>
                Delete Game
            </LumexButton>
        </div>
    </ToolbarContent>
    <ChildContent>
        <PropertyColumn Property="@(p => p.Image )">
            <Content>
                <img src="@context.Image" class="w-[100px] h-[100px] object-cover object-top" />
            </Content>
        </PropertyColumn>
        <PropertyColumn Property="@(p => p.Name)" />
    </ChildContent>
</LumexDataGrid>


@if (_showDeleteModal)
{
    <ModalDelete OnResult="@DeleteSelected" _open="_showDeleteModal" Header="Delete game" Description="Are you sure you want to delete the selected game?" />
}

@code {
    private IQueryable<mdGame> _games => Db.Games;
    private ICollection<mdGame> _selectedGames = [];
    private int _refreshKey;
    private bool _showDeleteModal = false;

    protected override async Task OnInitializedAsync()
    {
        await UpdateData();
    }

    private async Task UpdateData()
    {
        _refreshKey++;
        StateHasChanged();
    }


    private async Task DeleteSelected(bool confirmed)
    {
        _showDeleteModal = false;
        if (!confirmed) return;

        Db.Games.RemoveRange(_selectedGames);
        await Db.SaveChangesAsync();
        await UpdateData();
    }

}

