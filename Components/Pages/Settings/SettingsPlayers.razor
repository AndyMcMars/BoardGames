@using LumexUI.Common
@using Microsoft.EntityFrameworkCore

@inject AppDbContext Db
@inject NavigationManager Nav


<LumexDataGrid Data="@_players" SelectionMode="@SelectionMode.Multiple" @bind-SelectedItems="_selectedPlayers">
    <ToolbarContent>
        <div class="max-w-sm">
            <ModalPlayer />
            <LumexButton OnClick="DeleteSelected" Disabled="_selectedPlayers.Count < 1">Delete Selected</LumexButton>
        </div>
    </ToolbarContent>
    <ChildContent>
        <PropertyColumn Property="@(p => p.Name)" />
        <PropertyColumn Property="@(p => p.CreatedAt)" />
    </ChildContent>
</LumexDataGrid>

@code {
    private IQueryable<mdPlayer> _players => Db.Players;
    private ICollection<mdPlayer> _selectedPlayers = [];

    private void Reload()
    {
        StateHasChanged();
    }


    private async Task DeleteSelected()
    {
        Db.Players.RemoveRange(_selectedPlayers);
        await Db.SaveChangesAsync();
        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }

}

