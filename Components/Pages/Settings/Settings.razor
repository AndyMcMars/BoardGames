@page "/settings"
@using BoardGames.Components.Pages.Icons
@using LumexUI.Common
@using LumexUI.Shared.Icons

@inject NavigationManager Nav

@inject IJSRuntime JS


<p class="text-xl mb-4">@SharedResource.Settings_Settings</p>

<div class="flex flex-col max-w-sm gap-4">
    <LumexSelect TValue="string" Label="@SharedResource.Settings_Language" Value="@selectedCulture" ValueChanged="OnCultureChanged">
        <LumexSelectItem Value="@("fr")" TextValue="French">French</LumexSelectItem>
        <LumexSelectItem Value="@("en")" TextValue="English">English</LumexSelectItem>
        <LumexSelectItem Value="@("it")" TextValue="Italiano">Italiano</LumexSelectItem>
        <LumexSelectItem Value="@("de")" TextValue="Deutsch">Deutsch</LumexSelectItem>
    </LumexSelect>

    <LumexSwitch Color="@ThemeColor.Primary"
                 Value="@isDark"
			     ValueChanged="OnDarkModeChanged">
        <StartContent>
            <SunIcon />
        </StartContent>
        <ChildContent>
            @SharedResource.Settings_DarkMode
        </ChildContent>
        <EndContent>
            <MoonIcon />
        </EndContent>
    </LumexSwitch>

    <LumexButton OnClick="InstallPWA">install PWA</LumexButton>
</div>

<AuthorizeView Roles="Admin">
    <Authorized>
        <p class="text-xl mb-4 mt-4">@SharedResource.Settings_Entities</p>

        <div class="flex flex-col">
            <LumexLink Href="/settings/games">@SharedResource.Settings_Games</LumexLink>
            <LumexLink Href="/settings/factions">@SharedResource.Settings_Factions</LumexLink>
            <LumexLink Href="/settings/players">@SharedResource.Settings_Players</LumexLink>
            <LumexLink Href="/settings/locations">@SharedResource.Settings_Locations</LumexLink>
            <LumexLink Href="/settings/tournaments">@SharedResource.GameMatches_Tournaments</LumexLink>
        </div>
    </Authorized>
</AuthorizeView>


@code {
    bool isDark;
    string selectedCulture;

    private IJSObjectReference? _pwaModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {

        if (!firstRender) return;

        _pwaModule = await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "/js/pwa.js");

        isDark = await JS.InvokeAsync<bool>("theme.getDark");

        selectedCulture = await JS.InvokeAsync<string>("culture.get");

        if (string.IsNullOrEmpty(selectedCulture))
        {
            selectedCulture = await JS.InvokeAsync<string>("culture.getBrowserCulture");

            await JS.InvokeVoidAsync("culture.set", selectedCulture);
        }

        StateHasChanged();
    }

    async Task OnDarkModeChanged(bool value)
    {
        isDark = value;
        await JS.InvokeVoidAsync("theme.setDark", isDark);
    }

    async Task OnCultureChanged(string value)
    {
        selectedCulture = value;
        await JS.InvokeVoidAsync("culture.set", value);
    }

    async Task InstallPWA()
    {
        await _pwaModule!.InvokeVoidAsync("registerServiceWorker");

        var installed = await _pwaModule!
            .InvokeAsync<bool>("installPWA");

        Console.WriteLine($"Installed: {installed}");
    }
}
