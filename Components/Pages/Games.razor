@page "/"
@using BoardGames.Components.Pages.Icons
@using LumexUI.Common
@using LumexUI.Shared.Icons
@using Microsoft.EntityFrameworkCore;
@using System.Globalization

@inject NavigationManager Nav
@inject AppDbContext Db

<LumexTextbox Placeholder="@SharedResource.Games_SearchByName"
              Class="max-w-sm"
                Behavior="@InputBehavior.OnInput"
                @bind-Value="@_nameFilter">
    <StartContent>
        <SearchIcon Size="20" />
    </StartContent>
</LumexTextbox>

<div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mt-4 justify-items-center mb-16">

    @foreach (var game in FilteredGames)
    {
        <LumexCard onclick="@(() => GoToMatches(game.Game.Slug))" Class="w-full max-w-sm cursor-pointer transition-colors hover:bg-gray-200">
            <div class="w-full aspect-square overflow-hidden flex items-center justify-center">
                @if (game.Game.Image != null)
                {
                    <img src="@game.Game.Image"
                            class="w-full h-full object-cover object-top" />
                }
                else
                {
                    <DicesIcon />
                }
            </div>
            <LumexCardFooter Blurred="@true">
                <div class="flex justify-between w-full">
                    <h2>@game.Game.Name</h2>
                    <LumexChip Variant="ChipVariant.Light">
                        <StartContent>  
                            @_matches?.Where(m=>m.GameId == game.Game.Id).Count()
                        </StartContent>
                        <ChildContent>
                            <SwordsIcon/>
                        </ChildContent>
                    </LumexChip>
                </div>
            </LumexCardFooter>
        </LumexCard>
    }
</div>

@code {

    private List<GameWithLastPlayed> _games = [];
    private List<mdMatch>? _matches;

    private List<GameWithLastPlayed> FilteredGames
    {
        get
        {
            var result = _games;

            if (!string.IsNullOrWhiteSpace(_nameFilter))
            {
                result = result
                    .Where(x => x.Game.Name.Contains(_nameFilter, StringComparison.OrdinalIgnoreCase))
                    .ToList();
            }

            return result;
        }
    }

    private string? _nameFilter;


    protected override async Task OnInitializedAsync()
    {
        _games = await Db.Games
            .Select(g => new GameWithLastPlayed
            {
                Game = g,
                LastPlayed = Db.Matches
                    .Where(m => m.GameId == g.Id)
                    .Max(m => (DateTime?)m.Date)
            })
            .OrderByDescending(x => x.LastPlayed)
            .ToListAsync();

        _matches = await Db.Matches.ToListAsync();
    }

    private void GoToMatches(string game_slug)
    {
        Nav.NavigateTo($"/{game_slug}");
    }

    public class GameWithLastPlayed
    {
        public mdGame Game { get; set; } = null!;
        public DateTime? LastPlayed { get; set; }
    }
}
