@page "/"
@using BoardGames.Components.Pages.Icons
@using LumexUI.Common
@using LumexUI.Shared.Icons
@using Microsoft.EntityFrameworkCore;
@using System.Globalization

@inject NavigationManager Nav
@inject AppDbContext Db

<LumexTextbox Placeholder="@SharedResource.Games_SearchByName"
              Class="max-w-sm"
                Behavior="@InputBehavior.OnInput"
                @bind-Value="@_nameFilter">
    <StartContent>
        <SearchIcon Size="20" />
    </StartContent>
</LumexTextbox>

<div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mt-4 justify-items-center">

    @foreach (var game in FilteredGames)
    {
        <LumexCard onclick="@(() => GoToMatches(game.Slug))" Class="w-full max-w-sm" Style="cursor: pointer">
            <div class="w-full aspect-square overflow-hidden flex items-center justify-center">
                @if (game.Image != null)
                {
                    <img src="@game.Image"
                         class="w-full h-full object-cover object-top" />
                }
                else
                {
                    <DicesIcon />
                }
            </div>
            <LumexCardFooter Blurred="@true">
                <div class="flex justify-between w-full">
                    <h2>@game.Name</h2>
                    <LumexChip Variant="ChipVariant.Light">
                        <StartContent>
                            @_matches?.Where(m=>m.GameId == game.Id).Count()
                        </StartContent>
                        <ChildContent>
                            <SwordsIcon/>
                        </ChildContent>
                    </LumexChip>
                </div>
            </LumexCardFooter>
        </LumexCard>
    }
</div>

@code {

    private List<mdGame>? _games;
    private List<mdMatch>? _matches;

    private List<mdGame> FilteredGames
    {
        get
        {
            var result = _games;

            if (!string.IsNullOrEmpty(_nameFilter) && result != null)
            {
                result = result.Where(u => u.Name.Contains(_nameFilter, StringComparison.OrdinalIgnoreCase)).ToList();
            }

            return result ?? new List<mdGame>();
        }
    }

    private string? _nameFilter;


    protected override async Task OnInitializedAsync()
    {
        _games = await Db.Games.ToListAsync();
        _matches = await Db.Matches.ToListAsync();
    }

    private void GoToMatches(string game_slug)
    {
        Nav.NavigateTo($"/{game_slug}");
    }
}
