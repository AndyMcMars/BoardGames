@page "/profile"
@using System.Security.Claims;
@using Microsoft.EntityFrameworkCore;
@using LumexUI.Common
@using ApexCharts;
@inject AuthenticationStateProvider AuthStateProvider
@inject AppDbContext Db
@inject IJSRuntime JS



<LumexUser Name="@_user.Identity?.Name">
    <AvatarContent>
        <LumexAvatar>
            <FallbackContent>
                <PawnIcon />
            </FallbackContent>
        </LumexAvatar>
    </AvatarContent>
</LumexUser>

<LumexDivider Class="my-4"/>

<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-4 justify-items-center">

    <LumexCard Class="w-full">
        <div class="w-full aspect-square flex flex-col items-start justify-center ml-6">

            <p class="text-6xl font-bold">
                @_matchCount
            </p>

            <p class="text-sm text-gray-500">
                match count
            </p>

        </div>
    </LumexCard>

    <LumexCard Class="w-full">
        <div class="w-full aspect-square flex flex-col items-start justify-center ml-6">

            <p class="text-6xl font-bold">
                @_winCount
            </p>

            <p class="text-sm text-gray-500">
                matches won
            </p>

        </div>
    </LumexCard>

    <LumexCard Class="w-full">
        <div class="w-full aspect-square flex flex-col items-start justify-center ml-6">

            <p class="text-4xl font-bold">
                @(_matchCount == 0 ? 0 : Math.Round((_winCount * 100.0) / _matchCount, 1)) %
            </p>

            <p class="text-sm text-gray-500">
                win rate
            </p>

        </div>
    </LumexCard>

    <LumexCard Class="w-full">
        <div class="w-full aspect-square flex flex-col items-start justify-center ml-6">

            <p class="text-2xl font-bold">
                @_mostPlayedGame
            </p>

            <p class="text-2xl">
                (@_mostPlayedGameTimes)
            </p>

            <p class="text-sm text-gray-500">
                most played game
            </p>

        </div>
    </LumexCard>
    
</div>

<LumexDivider Class="my-4"/>

<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4 w-full">
    <div class="w-full">
        <ApexChart TItem="MatchPerMonth"
                    Options="_chartOptions"
                    Title="Matches per Month">

            <ApexPointSeries TItem="MatchPerMonth"
                                Items="_matchesPerMonth"
                                Name="Matches"
                                XValue="@(e => e.Month)"
                             Color="@(isDark ? "#ffffff" : "#000000")"
                                YValue="@(e => e.Count)"
                                SeriesType="SeriesType.Bar" />
        </ApexChart>
    </div>
    <div class="w-full">
        <ApexChart TItem="GameDistribution"
                   Title="Games Played Distribution"
                   Options="_donutOptions">

            <ApexPointSeries TItem="GameDistribution"
                             Items="_gameDistribution"
                             SeriesType="SeriesType.Donut"
                             XValue="@(e => e.Game)"
                             YValue="@(e => e.Count)" />
        </ApexChart>
    </div>
</div>

@code {

    private List<mdMatch> _matches = [];
    private ClaimsPrincipal _user = new();
    private int _matchCount;
    private int _winCount;
    private string? _mostPlayedGame;
    private int? _mostPlayedGameTimes;
    private List<MatchPerMonth> _matchesPerMonth = [];
    private List<GameDistribution> _gameDistribution = [];
    private ApexChartOptions<GameDistribution>? _donutOptions;
    private bool isDark;

    private static readonly List<string> LightPalette = new()
    {
        "#000000", "#1A1A1A", "#333333", "#4D4D4D",
        "#666666", "#808080", "#999999", "#B3B3B3"
    };

    private static readonly List<string> DarkPalette = new()
    {
        "#FFFFFF", "#E6E6E6", "#CCCCCC", "#B3B3B3",
        "#999999", "#808080", "#666666", "#4D4D4D"
    };


    private ApexChartOptions<MatchPerMonth> _chartOptions = new()
    {
        Grid = new Grid
        {
            Show = false
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {

        if (!firstRender) return;

        isDark = await JS.InvokeAsync<bool>("theme.getDark");

        _donutOptions = GetDonutOptions();

        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;


        if (_user.Identity?.IsAuthenticated != true)
            return;

        var playerId = await Db.Players
            .Where(p => p.Name == _user.Identity!.Name)
            .Select(p => p.Id)
            .FirstOrDefaultAsync();

        _matchCount = await Db.Results
            .Where(r => r.PlayerId == playerId)
            .Select(r => r.MatchId)
            .Distinct()
            .CountAsync();

        _winCount = await Db.Matches
            .Where(m => m.Results.Any(r => r.PlayerId == playerId))
            .CountAsync(m =>
                m.Results
                    .OrderByDescending(r => r.Points)
                    .Select(r => r.PlayerId)
                    .FirstOrDefault() == playerId
            );

        var gameStats = await Db.Results
            .Where(r => r.PlayerId == playerId)
            .GroupBy(r => r.Match.Game.Name)
            .OrderByDescending(g => g.Count())
            .Select(g => new { Game = g.Key, Count = g.Count() })
            .FirstOrDefaultAsync();

        _mostPlayedGame = gameStats?.Game;
        _mostPlayedGameTimes = gameStats?.Count;

        var year = DateTime.Now.Year;
       
        var raw = await Db.Results
            .Where(r => r.PlayerId == playerId)
            .Select(r => r.Match)
            .Where(m => m.Date.Year == year)
            .GroupBy(m => m.Date.Month)
            .Select(g => new
            {
                Month = g.Key,
                Count = g.Count()
            })
            .ToListAsync();
            
        var lookup = raw.ToDictionary(x => x.Month, x => x.Count);

        _matchesPerMonth = Enumerable.Range(1, 12)
            .Select(m => new MatchPerMonth
            {
                Month = $"{year}-{m:D2}",
                Count = lookup.TryGetValue(m, out var count) ? count : 0
            })
            .ToList();


        _gameDistribution = await Db.Results
            .Where(r => r.PlayerId == playerId)
            .GroupBy(r => r.Match.Game.Name)
            .Select(g => new GameDistribution
            {
                Game = g.Key,
                Count = g.Count()
            })
            .OrderByDescending(x => x.Count)
            .ToListAsync();
        
        }

    public class MatchPerMonth
    {
        public string Month { get; set; } = "";
        public int Count { get; set; }
    }

    public class GameDistribution
    {
        public string Game { get; set; } = "";
        public int Count { get; set; }
    }

    private ApexChartOptions<GameDistribution> GetDonutOptions()
    {
        return new ApexChartOptions<GameDistribution>
        {
            Colors = isDark ? DarkPalette : LightPalette,
            PlotOptions = new PlotOptions
            {
                Pie = new PlotOptionsPie
                {
                    StartAngle = -90,
                    EndAngle = 90,
                    Donut = new PlotOptionsDonut
                    {
                        Labels = new DonutLabels
                        {
                            Total = new DonutLabelTotal
                            {
                                FontSize = "24px",
                                Formatter = @"function (w) {
                                return w.globals.seriesTotals.reduce((a, b) => a + b, 0)
                            }"
                            }
                        }
                    }
                }
            },
            Legend = new Legend
            {
                Position = LegendPosition.Top
            }
        };
    }

}
