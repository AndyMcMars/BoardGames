@page "/profile"
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore;
@inject AuthenticationStateProvider AuthStateProvider
@inject AppDbContext Db


<div class="flex items-center gap-2 my-4">
    <LumexAvatar>
        <FallbackContent>
            <PawnIcon />
        </FallbackContent>
    </LumexAvatar>

    <h2 class="text-base font-medium">
        @_user.Identity?.Name
    </h2>
</div>

<LumexDivider />

<div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mt-4 justify-items-center mb-4">

    <LumexCard Class="w-full max-w-sm">
        <div class="w-full aspect-square flex flex-col items-start justify-center ml-6">

            <p class="text-6xl font-bold">
                @_matchCount
            </p>

            <p class="text-sm text-gray-500">
                match count
            </p>

        </div>
    </LumexCard>

    <LumexCard Class="w-full max-w-sm">
        <div class="w-full aspect-square flex flex-col items-start justify-center ml-6">

            <p class="text-6xl font-bold">
                @_winCount
            </p>

            <p class="text-sm text-gray-500">
                matches won
            </p>

        </div>
    </LumexCard>

    <LumexCard Class="w-full max-w-sm">
        <div class="w-full aspect-square flex flex-col items-start justify-center ml-6">

            <p class="text-4xl font-bold">
                @(_matchCount == 0 ? 0 : Math.Round((_winCount * 100.0) / _matchCount, 1)) %
            </p>

            <p class="text-sm text-gray-500">
                win rate
            </p>

        </div>
    </LumexCard>

    <LumexCard Class="w-full max-w-sm">
        <div class="w-full aspect-square flex flex-col items-start justify-center ml-6">

            <p class="text-2xl font-bold">
                @_mostPlayedGame
            </p>

            <p class="text-2xl">
                (@_mostPlayedGameTimes)
            </p>

            <p class="text-sm text-gray-500">
                most played game
            </p>

        </div>
    </LumexCard>
    
</div>


@code {

    private List<mdMatch> _matches = [];
    private ClaimsPrincipal _user = new();
    private int _matchCount;
    private int _winCount;
    private string? _mostPlayedGame;
    private int? _mostPlayedGameTimes;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;

        if (_user.Identity?.IsAuthenticated != true)
            return;

        var playerId = await Db.Players
            .Where(p => p.Name == _user.Identity!.Name)
            .Select(p => p.Id)
            .FirstOrDefaultAsync();

        _matchCount = await Db.Results
            .Where(r => r.PlayerId == playerId)
            .Select(r => r.MatchId)
            .Distinct()
            .CountAsync();

        _winCount = await Db.Matches
            .Where(m => m.Results.Any(r => r.PlayerId == playerId))
            .CountAsync(m =>
                m.Results
                    .OrderByDescending(r => r.Points)
                    .Select(r => r.PlayerId)
                    .FirstOrDefault() == playerId
            );

        var gameStats = await Db.Results
            .Where(r => r.PlayerId == playerId)
            .GroupBy(r => r.Match.Game.Name)
            .OrderByDescending(g => g.Count())
            .Select(g => new { Game = g.Key, Count = g.Count() })
            .FirstOrDefaultAsync();

        _mostPlayedGame = gameStats?.Game;
        _mostPlayedGameTimes = gameStats?.Count;
    }

}
